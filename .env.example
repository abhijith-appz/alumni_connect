# ─────────────────────────────────────────────────────────────────────────────
# AlumniConnect — Environment Variables
# Copy this file:  cp .env.example .env
# Generate SECRET_KEY:  python3 -c "import secrets; print(secrets.token_urlsafe(50))"
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED
SECRET_KEY=u11em83cHqkW0UiRUULOw07sb_ts5V7QViEhP9b_As130Ij6EGSXqMoQ3h4Y9wF98M0

# Development settings (leave as-is for local dev)
DEBUG=True
ALLOWED_HOSTS=localhost 127.0.0.1

# AI Features (get free key at https://console.anthropic.com)
# Leave blank to disable AI — all other features still work
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Email (console = prints emails to terminal, good for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Database (SQLite is default — no config needed for development)
# Uncomment below ONLY if using PostgreSQL:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=alumni_db
# DB_USER=alumni_user
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
